package com.sthi.service.astro;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;
import swisseph.*;
import java.time.*;
import java.util.*;

@Service
@Slf4j
@RequiredArgsConstructor
public class AstroCalculationService {
    private final SwissEph swissEph;
    private final GeoCodingService geoCodingService;

    public AstroData calculate(ReportRequest request) {
        // 1. Convert birth details to Julian Day (UT)
        double julianDay = calculateJulianDay(request.getBirthDate(), request.getBirthTime());

        // 2. Geocode birth place to latitude/longitude
        double[] coordinates = geoCodingService.getCoordinates(request.getBirthPlace());
        double geoLat = coordinates[0];
        double geoLon = coordinates[1];

        // 3. Calculate sidereal positions
        int flags = SweConst.SEFLG_SWIEPH | SweConst.SEFLG_SIDEREAL | SweConst.SEFLG_TRUEPOS;
        Map<String, Double> planetPositions = calculatePlanetPositions(julianDay, flags);

        // 4. Calculate Ascendant (Lagna) and House cusps (Whole Sign)
        double[] cusps = new double[13];
        double[] ascmc = new double[10];
        String serr = new String();
        swissEph.swe_houses(julianDay, geoLat, geoLon, 'W', cusps, ascmc);
        double ascendant = ascmc[0];
        String lagna = getZodiacSign(ascendant);

        // 5. Calculate Nakshatra & Pada
        double moonLong = planetPositions.get("Moon");
        String[] nakshatraInfo = getNakshatraAndPada(moonLong);
        String nakshatra = nakshatraInfo[0];
        int pada = Integer.parseInt(nakshatraInfo[1]);

        // 6. Calculate Tithi, Yoga, Karana (simplified logic)
        double sunLong = planetPositions.get("Sun");
        double moonLong = planetPositions.get("Moon");
        String tithi = calculateTithi(sunLong, moonLong);
        String yoga = calculateYoga(sunLong, moonLong);
        String karana = calculateKarana(sunLong, moonLong);

        // 7. Calculate Sunrise/Sunset (Topocentric)
        String[] riseSet = calculateSunriseSunset(request.getBirthDate(), geoLat, geoLon);
        String sunrise = riseSet[0];
        String sunset = riseSet[1];

        // 8. Detect Doshas
        List<String> doshas = detectDoshas(planetPositions, cusps);

        // 9. Build AstroData
        AstroData data = new AstroData();
        data.setLagna(lagna);
        data.setSunSign(getZodiacSign(sunLong));
        data.setMoonSign(getZodiacSign(moonLong));
        data.setNakshatra(nakshatra);
        data.setPada(pada);
        data.setPlanetPositions(planetPositions);
        data.setDoshas(doshas);
        data.setSunrise(sunrise);
        data.setSunset(sunset);
        data.setTithi(tithi);
        data.setYoga(yoga);
        data.setKarana(karana);
        return data;
    }

    private Map<String, Double> calculatePlanetPositions(double julianDay, int flags) {
        Map<String, Double> positions = new HashMap<>();
        int[] planets = {SweConst.SE_SUN, SweConst.SE_MOON, SweConst.SE_MARS,
                         SweConst.SE_MERCURY, SweConst.SE_JUPITER,
                         SweConst.SE_VENUS, SweConst.SE_SATURN,
                         SweConst.SE_TRUE_NODE}; // Rahu (true node)
        String[] names = {"Sun", "Moon", "Mars", "Mercury", "Jupiter",
                          "Venus", "Saturn", "Rahu"};
        double[] xx = new double[6];
        String serr = new String();
        for (int i = 0; i < planets.length; i++) {
            int ret = swissEph.swe_calc(julianDay, planets[i], flags, xx, serr);
            if (ret == SweConst.OK) {
                positions.put(names[i], xx[0]); // longitude in degrees
            }
        }
        // Ketu is opposite Rahu
        double rahuLong = positions.get("Rahu");
        double ketuLong = (rahuLong + 180.0) % 360.0;
        positions.put("Ketu", ketuLong);
        return positions;
    }

    private List<String> detectDoshas(Map<String, Double> positions, double[] cusps) {
        List<String> doshas = new ArrayList<>();
        // Simplified detection logic (implement full rules per Drik Panchang)
        // 1. Manglik: Mars in 1, 4, 7, 8, 12
        double marsLong = positions.get("Mars");
        int marsHouse = getHouse(marsLong, cusps);
        if (marsHouse == 1 || marsHouse == 4 || marsHouse == 7 ||
            marsHouse == 8 || marsHouse == 12) {
            doshas.add("Manglik");
        }
        // 2. Kaal Sarp: All planets between Rahu and Ketu
        double rahuLong = positions.get("Rahu");
        double ketuLong = positions.get("Ketu");
        if (isKaalSarp(positions, rahuLong, ketuLong)) {
            doshas.add("Kaal Sarp");
        }
        // 3. Other doshas...
        return doshas;
    }

    private String[] calculateSunriseSunset(LocalDate date, double geoLat, double geoLon) {
        double julianDay = calculateJulianDay(date, LocalTime.of(0, 0));
        double[] riseSet = new double[2];
        String serr = new String();
        // SE_CALC_RISE + SE_BIT_DISC_CENTER + SE_BIT_NO_REFRACTION
        int ret = swissEph.swe_rise_trans(julianDay, SweConst.SE_SUN, null,
                SweConst.SEFLG_SWIEPH, SweConst.SE_CALC_RISE,
                new double[]{geoLon, geoLat, 0.0}, 0.0, 0.0, riseSet, serr);
        // Similarly for SET
        // Convert julian day to local time...
        return new String[]{"06:00", "18:00"}; // placeholder
    }

    // Helper methods: getZodiacSign, getNakshatraAndPada, calculateTithi, etc.
    // Refer to Drik Panchang algorithms for exact formulas.
}
